# Clean URL trailing slash normalization
/pages/contact    /pages/contact/  301
/pages/about      /pages/about/    301
/pages/tools      /pages/tools/    301
/pages/donate     /pages/donate/   301
/pages/admin      /pages/admin/    301
/pages/new        /pages/new/      301
/pages/leaderboard /pages/leaderboard/ 301
/pages/sites      /pages/sites/    301
/pages/settings   /pages/settings/ 301
/pages/import     /pages/import/   301

# Dynamic detail pages (site/category/tag/blog) — all routed through the single
# router in 404.html, which already contains the full renderSiteDetailPage /
# renderCategoryPage / renderTagPage / renderBlogPage implementation.
# Bare index paths (/category/, /tag/, /blog/, /site/) are NOT rewritten here —
# those are real files served natively by Cloudflare. Rewriting them to their
# own index.html causes a redirect loop against Cloudflare's own
# index.html -> clean-URL canonicalization, so leave them alone.
/category         /category/       301
/category/:slug   /404.html        200
/category/:slug/  /404.html        200

/tag              /tag/            301
/tag/:slug        /404.html        200
/tag/:slug/       /404.html        200

/search           /search/         301

/blog             /blog/           301
/blog/:slug       /404.html        200
/blog/:slug/      /404.html        200

# RSS feed
/feed.xml         https://tiupkpabwuefclbrpaef.supabase.co/functions/v1/rss-feed 302

# Sites sitemap — generated dynamically from the sites table (real lastmod per site)
/sitemap-sites.xml https://tiupkpabwuefclbrpaef.supabase.co/functions/v1/sitemap-sites 302

/site             /site/           301
/site/:slug       /404.html        200
/site/:slug/      /404.html        200

# Legacy uppercase paths → lowercase
/Pages/contact/*  /pages/contact/  301
/Pages/about/*    /pages/about/    301
/Pages/tools/*    /pages/tools/    301
/Pages/donate/*   /pages/donate/   301
/Pages/admin/*    /pages/admin/    301
